{
  "info": {
    "_postman_id": "election-module-collection-v2",
    "name": "Nextora - Election & Voting Module",
    "description": "Complete Postman collection for the Election & Voting Module.\n\nIncludes:\n- Election CRUD Operations\n- Election Lifecycle Management\n- Candidate Nominations & Reviews\n- Voting & Vote Verification\n- Results & Statistics\n- Admin Election Management\n\nValid Election Types:\n- PRESIDENT\n- VICE_PRESIDENT\n- SECRETARY\n- TREASURER\n- GENERAL\n- POLL\n- REFERENDUM",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "token",
      "value": "YOUR_JWT_TOKEN_HERE",
      "type": "string"
    },
    {
      "key": "clubId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "electionId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "candidateId",
      "value": "1",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "01. Election Management",
      "description": "Election CRUD operations: create, read, update, delete elections",
      "item": [
        {
          "name": "Create Election",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"2026 Club President Election\",\n  \"description\": \"Annual election for club president\",\n  \"clubId\": {{clubId}},\n  \"electionType\": \"PRESIDENT\",\n  \"nominationStartTime\": \"2026-03-20T09:00:00\",\n  \"nominationEndTime\": \"2026-03-25T17:00:00\",\n  \"votingStartTime\": \"2026-03-27T09:00:00\",\n  \"votingEndTime\": \"2026-03-28T17:00:00\",\n  \"maxCandidates\": 10,\n  \"winnersCount\": 1,\n  \"isAnonymousVoting\": true,\n  \"requireManifesto\": true,\n  \"eligibilityCriteria\": \"Must be active member\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/club/election",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "club",
                "election"
              ]
            },
            "description": "Create a new election. Valid electionType values: PRESIDENT, VICE_PRESIDENT, SECRETARY, TREASURER, GENERAL, POLL, REFERENDUM"
          }
        },
        {
          "name": "Get Election by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/club/election/{{electionId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "club",
                "election",
                "{{electionId}}"
              ]
            },
            "description": "Get election details by ID"
          }
        },
        {
          "name": "Update Election",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"2026 Club President Election - Updated\",\n  \"description\": \"Updated description\",\n  \"maxCandidates\": 15\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/club/election/{{electionId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "club",
                "election",
                "{{electionId}}"
              ]
            },
            "description": "Update election details (only in DRAFT status)"
          }
        },
        {
          "name": "Delete Election",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/v1/club/election/{{electionId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "club",
                "election",
                "{{electionId}}"
              ]
            },
            "description": "Delete a draft election"
          }
        },
        {
          "name": "Get Elections by Club",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/club/election/club/{{clubId}}?page=0&size=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "club",
                "election",
                "club",
                "{{clubId}}"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                }
              ]
            },
            "description": "Get all elections for a specific club"
          }
        },
        {
          "name": "Get Elections by Status",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/club/election/status/VOTING_OPEN?page=0&size=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "club",
                "election",
                "status",
                "VOTING_OPEN"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                }
              ]
            },
            "description": "Get elections by status (DRAFT, NOMINATION_OPEN, NOMINATION_CLOSED, VOTING_OPEN, VOTING_CLOSED, RESULTS_PUBLISHED, CANCELLED, ARCHIVED)"
          }
        },
        {
          "name": "Get Upcoming Elections",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/club/election/upcoming?page=0&size=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "club",
                "election",
                "upcoming"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                }
              ]
            },
            "description": "Get all upcoming elections"
          }
        },
        {
          "name": "Search Elections",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/club/election/search?keyword=president&page=0&size=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "club",
                "election",
                "search"
              ],
              "query": [
                {
                  "key": "keyword",
                  "value": "president"
                },
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                }
              ]
            },
            "description": "Search elections by keyword"
          }
        }
      ]
    },
    {
      "name": "02. Election Lifecycle",
      "description": "Manage election state transitions",
      "item": [
        {
          "name": "Open Nominations",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/v1/club/election/{{electionId}}/open-nominations",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "club",
                "election",
                "{{electionId}}",
                "open-nominations"
              ]
            },
            "description": "Transition from DRAFT to NOMINATION_OPEN"
          }
        },
        {
          "name": "Close Nominations",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/v1/club/election/{{electionId}}/close-nominations",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "club",
                "election",
                "{{electionId}}",
                "close-nominations"
              ]
            },
            "description": "Transition from NOMINATION_OPEN to NOMINATION_CLOSED"
          }
        },
        {
          "name": "Open Voting",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/v1/club/election/{{electionId}}/open-voting",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "club",
                "election",
                "{{electionId}}",
                "open-voting"
              ]
            },
            "description": "Transition from NOMINATION_CLOSED to VOTING_OPEN (requires 2+ approved candidates)"
          }
        },
        {
          "name": "Close Voting",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/v1/club/election/{{electionId}}/close-voting",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "club",
                "election",
                "{{electionId}}",
                "close-voting"
              ]
            },
            "description": "Transition from VOTING_OPEN to VOTING_CLOSED"
          }
        },
        {
          "name": "Publish Results",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/v1/club/election/{{electionId}}/publish-results",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "club",
                "election",
                "{{electionId}}",
                "publish-results"
              ]
            },
            "description": "Transition from VOTING_CLOSED to RESULTS_PUBLISHED"
          }
        },
        {
          "name": "Cancel Election",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Postponing due to scheduling conflict\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/club/election/{{electionId}}/cancel",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "club",
                "election",
                "{{electionId}}",
                "cancel"
              ]
            },
            "description": "Cancel an election at any point"
          }
        }
      ]
    },
    {
      "name": "03. Voting",
      "description": "Cast votes and verify votes",
      "item": [
        {
          "name": "Cast Vote",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"electionId\": {{electionId}},\n  \"candidateId\": {{candidateId}}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/club/election/vote",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "club",
                "election",
                "vote"
              ]
            },
            "description": "Cast your vote for a candidate (returns verification token)"
          }
        },
        {
          "name": "Check if Voted",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/club/election/{{electionId}}/has-voted",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "club",
                "election",
                "{{electionId}}",
                "has-voted"
              ]
            },
            "description": "Check if current user has voted"
          }
        },
        {
          "name": "Verify Vote",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/club/election/{{electionId}}/verify-vote?token=VERIFICATION_TOKEN",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "club",
                "election",
                "{{electionId}}",
                "verify-vote"
              ],
              "query": [
                {
                  "key": "token",
                  "value": "VERIFICATION_TOKEN"
                }
              ]
            },
            "description": "Verify your vote using the verification token"
          }
        }
      ]
    },
    {
      "name": "04. Results",
      "description": "View election results",
      "item": [
        {
          "name": "Get Election Results",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/club/election/{{electionId}}/results",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "club",
                "election",
                "{{electionId}}",
                "results"
              ]
            },
            "description": "Get election results (available after RESULTS_PUBLISHED)"
          }
        },
        {
          "name": "Get Live Vote Count (Admin)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/club/election/{{electionId}}/live-count",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "club",
                "election",
                "{{electionId}}",
                "live-count"
              ]
            },
            "description": "Get real-time vote counts (Admin only, during VOTING_OPEN)"
          }
        }
      ]
    }
  ]
}

