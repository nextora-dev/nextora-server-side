{
	"info": {
		"_postman_id": "club-module-collection",
		"name": "Nextora - Club Module",
		"description": "Complete Postman collection for the Club Module.\n\nIncludes:\n- Club Management (CRUD)\n- Membership Management (join, approve, reject, suspend, leave)\n- Club Announcements (CRUD, pin/unpin)\n- Club Admin (statistics, activity logs, bulk approve, change position, toggle registration)\n\n**Auth:** Set `{{token}}` variable with a valid JWT Bearer token.\n**Base URL:** Set `{{baseUrl}}` variable (default: http://localhost:8080)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8080",
			"type": "string"
		},
		{
			"key": "token",
			"value": "YOUR_JWT_TOKEN_HERE",
			"type": "string"
		},
		{
			"key": "clubId",
			"value": "1",
			"type": "string"
		},
		{
			"key": "membershipId",
			"value": "1",
			"type": "string"
		},
		{
			"key": "announcementId",
			"value": "1",
			"type": "string"
		}
	],
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{token}}",
				"type": "string"
			}
		]
	},
	"item": [
		{
			"name": "01. Club Management",
			"description": "Club CRUD operations (Admin/Club Officers)",
			"item": [
				{
					"name": "Create Club (with logo)",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{ "key": "name", "value": "Computing Society", "type": "text" },
								{ "key": "clubCode", "value": "CS-001", "type": "text" },
								{ "key": "description", "value": "A club for computing enthusiasts", "type": "text" },
								{ "key": "email", "value": "computing@iit.ac.lk", "type": "text" },
								{ "key": "contactNumber", "value": "0771234567", "type": "text" },
								{ "key": "faculty", "value": "COMPUTING", "type": "text" },
								{ "key": "establishedDate", "value": "2024-01-15", "type": "text" },
								{ "key": "maxMembers", "value": "200", "type": "text" },
								{ "key": "socialMediaLinks", "value": "https://facebook.com/cs-iit", "type": "text" },
								{ "key": "presidentId", "value": "", "type": "text", "disabled": true },
								{ "key": "advisorId", "value": "", "type": "text", "disabled": true },
								{ "key": "isRegistrationOpen", "value": "true", "type": "text" },
								{ "key": "logo", "type": "file", "src": "" }
							]
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/club",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "club"]
						},
						"description": "Create a new club with optional logo upload.\n\n**Permission:** CLUB:CREATE\n**Role:** Admin, Super Admin, Non-Academic Staff"
					}
				},
				{
					"name": "Get Club by ID",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/api/v1/club/{{clubId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "club", "{{clubId}}"]
						},
						"description": "Get club details by ID.\n\n**Permission:** CLUB:READ"
					}
				},
				{
					"name": "Get Club by Code",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/api/v1/club/code/CS-001",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "club", "code", "CS-001"]
						},
						"description": "Get club details by club code.\n\n**Permission:** CLUB:READ"
					}
				},
				{
					"name": "Get All Clubs (paginated)",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/api/v1/club?page=0&size=10&sortBy=name&sortDirection=ASC",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "club"],
							"query": [
								{ "key": "page", "value": "0" },
								{ "key": "size", "value": "10" },
								{ "key": "sortBy", "value": "name" },
								{ "key": "sortDirection", "value": "ASC" }
							]
						},
						"description": "Get all active clubs with pagination and sorting.\n\n**Permission:** CLUB:READ"
					}
				},
				{
					"name": "Search Clubs",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/api/v1/club/search?keyword=computing&page=0&size=10",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "club", "search"],
							"query": [
								{ "key": "keyword", "value": "computing" },
								{ "key": "page", "value": "0" },
								{ "key": "size", "value": "10" }
							]
						},
						"description": "Search clubs by keyword (name/description).\n\n**Permission:** CLUB:READ"
					}
				},
				{
					"name": "Get Clubs by Faculty",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/api/v1/club/faculty/COMPUTING?page=0&size=10",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "club", "faculty", "COMPUTING"],
							"query": [
								{ "key": "page", "value": "0" },
								{ "key": "size", "value": "10" }
							]
						},
						"description": "Get clubs filtered by faculty.\n\nValid values: COMPUTING, ENGINEERING, BUSINESS, etc.\n\n**Permission:** CLUB:READ"
					}
				},
				{
					"name": "Get Clubs Open for Registration",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/api/v1/club/open-registration?page=0&size=10",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "club", "open-registration"],
							"query": [
								{ "key": "page", "value": "0" },
								{ "key": "size", "value": "10" }
							]
						},
						"description": "Get clubs that are currently accepting new members.\n\n**Permission:** CLUB:READ"
					}
				},
				{
					"name": "Update Club (with logo)",
					"request": {
						"method": "PUT",
						"body": {
							"mode": "formdata",
							"formdata": [
								{ "key": "name", "value": "Computing Society - Updated", "type": "text" },
								{ "key": "description", "value": "Updated description", "type": "text" },
								{ "key": "email", "value": "cs-updated@iit.ac.lk", "type": "text" },
								{ "key": "contactNumber", "value": "0779876543", "type": "text" },
								{ "key": "faculty", "value": "COMPUTING", "type": "text", "disabled": true },
								{ "key": "maxMembers", "value": "300", "type": "text" },
								{ "key": "socialMediaLinks", "value": "https://twitter.com/cs-iit", "type": "text" },
								{ "key": "isRegistrationOpen", "value": "true", "type": "text" },
								{ "key": "logo", "type": "file", "src": "" }
							]
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/club/{{clubId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "club", "{{clubId}}"]
						},
						"description": "Update club details with optional new logo.\n\n**Permission:** CLUB:UPDATE\n**Role:** President, Admin, Non-Academic Staff"
					}
				},
				{
					"name": "Delete Club (soft delete)",
					"request": {
						"method": "DELETE",
						"url": {
							"raw": "{{baseUrl}}/api/v1/club/{{clubId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "club", "{{clubId}}"]
						},
						"description": "Soft delete a club. Also deletes logo from S3.\n\n**Permission:** CLUB:DELETE\n**Role:** President, Admin, Super Admin"
					}
				},
				{
					"name": "Get Club Statistics",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/api/v1/club/{{clubId}}/statistics",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "club", "{{clubId}}", "statistics"]
						},
						"description": "Get detailed statistics for a club (members, pending, announcements).\n\n**Permission:** CLUB:READ"
					}
				},
				{
					"name": "Toggle Registration Open/Closed",
					"request": {
						"method": "PUT",
						"url": {
							"raw": "{{baseUrl}}/api/v1/club/{{clubId}}/toggle-registration",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "club", "{{clubId}}", "toggle-registration"]
						},
						"description": "Toggle club registration open/closed.\n\n**Permission:** CLUB:UPDATE\n**Role:** President, Admin"
					}
				}
			]
		},
		{
			"name": "02. Membership Management",
			"description": "Club membership operations (join, approve, reject, suspend, leave)",
			"item": [
				{
					"name": "Join Club",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"clubId\": {{clubId}},\n    \"position\": null,\n    \"remarks\": \"I want to join this club\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/club/join",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "club", "join"]
						},
						"description": "Apply to join a club. Creates a PENDING membership.\n\n**Permission:** CLUB_MEMBERSHIP:VIEW\n**Role:** Any student"
					}
				},
				{
					"name": "Approve Membership",
					"request": {
						"method": "POST",
						"url": {
							"raw": "{{baseUrl}}/api/v1/club/memberships/{{membershipId}}/approve",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "club", "memberships", "{{membershipId}}", "approve"]
						},
						"description": "Approve a pending membership application.\n\n**Permission:** CLUB_MEMBERSHIP:MANAGE\n**Role:** Club Officers (President, VP, Secretary, Treasurer, Committee), Admin, Non-Academic Staff"
					}
				},
				{
					"name": "Reject Membership",
					"request": {
						"method": "POST",
						"url": {
							"raw": "{{baseUrl}}/api/v1/club/memberships/{{membershipId}}/reject?reason=Does not meet requirements",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "club", "memberships", "{{membershipId}}", "reject"],
							"query": [
								{ "key": "reason", "value": "Does not meet requirements" }
							]
						},
						"description": "Reject a pending membership application with a reason.\n\n**Permission:** CLUB_MEMBERSHIP:MANAGE"
					}
				},
				{
					"name": "Suspend Membership",
					"request": {
						"method": "POST",
						"url": {
							"raw": "{{baseUrl}}/api/v1/club/memberships/{{membershipId}}/suspend?reason=Violation of club rules",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "club", "memberships", "{{membershipId}}", "suspend"],
							"query": [
								{ "key": "reason", "value": "Violation of club rules" }
							]
						},
						"description": "Suspend an active membership.\n\n**Permission:** CLUB_MEMBERSHIP:MANAGE"
					}
				},
				{
					"name": "Get Club Members (all)",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/api/v1/club/{{clubId}}/members?page=0&size=10",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "club", "{{clubId}}", "members"],
							"query": [
								{ "key": "page", "value": "0" },
								{ "key": "size", "value": "10" }
							]
						},
						"description": "Get all members of a club (all statuses).\n\n**Permission:** CLUB_MEMBERSHIP:VIEW"
					}
				},
				{
					"name": "Get Active Club Members",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/api/v1/club/{{clubId}}/members/active?page=0&size=10",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "club", "{{clubId}}", "members", "active"],
							"query": [
								{ "key": "page", "value": "0" },
								{ "key": "size", "value": "10" }
							]
						},
						"description": "Get only active (non-expired, non-suspended) members.\n\n**Permission:** CLUB_MEMBERSHIP:VIEW"
					}
				},
				{
					"name": "Get Pending Applications",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/api/v1/club/{{clubId}}/members/pending?page=0&size=10",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "club", "{{clubId}}", "members", "pending"],
							"query": [
								{ "key": "page", "value": "0" },
								{ "key": "size", "value": "10" }
							]
						},
						"description": "Get pending membership applications (Club Admin only).\n\n**Permission:** CLUB_MEMBERSHIP:MANAGE"
					}
				},
				{
					"name": "Get My Memberships",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/api/v1/club/my-memberships?page=0&size=10",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "club", "my-memberships"],
							"query": [
								{ "key": "page", "value": "0" },
								{ "key": "size", "value": "10" }
							]
						},
						"description": "Get current user's club memberships across all clubs.\n\n**Permission:** CLUB_MEMBERSHIP:VIEW"
					}
				},
				{
					"name": "Get Membership by ID",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/api/v1/club/memberships/{{membershipId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "club", "memberships", "{{membershipId}}"]
						},
						"description": "Get membership details by ID.\n\n**Permission:** CLUB_MEMBERSHIP:VIEW"
					}
				},
				{
					"name": "Leave Club",
					"request": {
						"method": "DELETE",
						"url": {
							"raw": "{{baseUrl}}/api/v1/club/{{clubId}}/leave",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "club", "{{clubId}}", "leave"]
						},
						"description": "Leave a club (soft deletes membership).\n\n**Permission:** CLUB_MEMBERSHIP:VIEW"
					}
				}
			]
		},
		{
			"name": "03. Club Announcements",
			"description": "Club announcement CRUD, pin/unpin, visibility control",
			"item": [
				{
					"name": "Create Announcement (with attachment)",
					"request": {
						"method": "POST",
						"body": {
							"mode": "formdata",
							"formdata": [
								{ "key": "clubId", "value": "{{clubId}}", "type": "text" },
								{ "key": "title", "value": "Welcome New Members!", "type": "text" },
								{ "key": "content", "value": "We are excited to welcome all new members to the Computing Society. Our first meeting will be held next week.", "type": "text" },
								{ "key": "priority", "value": "HIGH", "type": "text" },
								{ "key": "isPinned", "value": "true", "type": "text" },
								{ "key": "isMembersOnly", "value": "false", "type": "text" },
								{ "key": "attachment", "type": "file", "src": "" }
							]
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/club/announcements",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "club", "announcements"]
						},
						"description": "Create a new club announcement with optional file attachment.\n\n**Priority values:** LOW, NORMAL, HIGH, URGENT\n\n**Permission:** CLUB_ANNOUNCEMENT:CREATE\n**Role:** Club Officers, Admin, Non-Academic Staff"
					}
				},
				{
					"name": "Update Announcement",
					"request": {
						"method": "PUT",
						"body": {
							"mode": "formdata",
							"formdata": [
								{ "key": "title", "value": "Updated Announcement Title", "type": "text" },
								{ "key": "content", "value": "Updated announcement content with more details.", "type": "text" },
								{ "key": "priority", "value": "NORMAL", "type": "text" },
								{ "key": "isPinned", "value": "false", "type": "text" },
								{ "key": "isMembersOnly", "value": "true", "type": "text" },
								{ "key": "attachment", "type": "file", "src": "" }
							]
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/club/announcements/{{announcementId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "club", "announcements", "{{announcementId}}"]
						},
						"description": "Update an existing announcement. All fields optional.\n\n**Permission:** CLUB_ANNOUNCEMENT:UPDATE"
					}
				},
				{
					"name": "Get Announcement by ID",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/api/v1/club/announcements/{{announcementId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "club", "announcements", "{{announcementId}}"]
						},
						"description": "Get announcement details. Increments view count.\n\n**Permission:** CLUB_ANNOUNCEMENT:READ"
					}
				},
				{
					"name": "Delete Announcement",
					"request": {
						"method": "DELETE",
						"url": {
							"raw": "{{baseUrl}}/api/v1/club/announcements/{{announcementId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "club", "announcements", "{{announcementId}}"]
						},
						"description": "Soft delete an announcement.\n\n**Permission:** CLUB_ANNOUNCEMENT:DELETE"
					}
				},
				{
					"name": "Get Announcements by Club",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/api/v1/club/announcements/club/{{clubId}}?page=0&size=10",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "club", "announcements", "club", "{{clubId}}"],
							"query": [
								{ "key": "page", "value": "0" },
								{ "key": "size", "value": "10" }
							]
						},
						"description": "Get all announcements for a club (pinned first, then by date).\n\n**Permission:** CLUB_ANNOUNCEMENT:READ"
					}
				},
				{
					"name": "Get Public Announcements by Club",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/api/v1/club/announcements/club/{{clubId}}/public?page=0&size=10",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "club", "announcements", "club", "{{clubId}}", "public"],
							"query": [
								{ "key": "page", "value": "0" },
								{ "key": "size", "value": "10" }
							]
						},
						"description": "Get only public (non-members-only) announcements.\n\n**Permission:** CLUB_ANNOUNCEMENT:READ"
					}
				},
				{
					"name": "Get Pinned Announcements by Club",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/api/v1/club/announcements/club/{{clubId}}/pinned?page=0&size=10",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "club", "announcements", "club", "{{clubId}}", "pinned"],
							"query": [
								{ "key": "page", "value": "0" },
								{ "key": "size", "value": "10" }
							]
						},
						"description": "Get only pinned announcements for a club.\n\n**Permission:** CLUB_ANNOUNCEMENT:READ"
					}
				},
				{
					"name": "Search Announcements",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/api/v1/club/announcements/search?keyword=meeting&page=0&size=10",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "club", "announcements", "search"],
							"query": [
								{ "key": "keyword", "value": "meeting" },
								{ "key": "page", "value": "0" },
								{ "key": "size", "value": "10" }
							]
						},
						"description": "Search announcements by keyword (title/content).\n\n**Permission:** CLUB_ANNOUNCEMENT:READ"
					}
				},
				{
					"name": "Pin Announcement",
					"request": {
						"method": "PUT",
						"url": {
							"raw": "{{baseUrl}}/api/v1/club/announcements/{{announcementId}}/pin",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "club", "announcements", "{{announcementId}}", "pin"]
						},
						"description": "Pin an announcement to top of the list.\n\n**Permission:** CLUB_ANNOUNCEMENT:UPDATE"
					}
				},
				{
					"name": "Unpin Announcement",
					"request": {
						"method": "PUT",
						"url": {
							"raw": "{{baseUrl}}/api/v1/club/announcements/{{announcementId}}/unpin",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "club", "announcements", "{{announcementId}}", "unpin"]
						},
						"description": "Unpin an announcement.\n\n**Permission:** CLUB_ANNOUNCEMENT:UPDATE"
					}
				}
			]
		},
		{
			"name": "04. Club Admin",
			"description": "Admin-only endpoints: statistics, activity logs, bulk operations, position management",
			"item": [
				{
					"name": "Get Club Statistics (Admin)",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/api/v1/admin/club/stats/{{clubId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "admin", "club", "stats", "{{clubId}}"]
						},
						"description": "Get detailed statistics for a specific club.\n\n**Permission:** CLUB:VIEW_STATS\n**Role:** Admin, Non-Academic Staff, Club Officers"
					}
				},
				{
					"name": "Get Club Statistics (Officer)",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/api/v1/admin/club/{{clubId}}/statistics",
							"host": ["{{baseUrl}}"],
