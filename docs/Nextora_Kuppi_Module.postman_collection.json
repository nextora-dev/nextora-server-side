{
	"info": {
		"_postman_id": "nextora-kuppi-module-api",
		"name": "Nextora - Kuppi Module API",
		"description": "Complete API collection for Nextora Kuppi Module including Sessions, Notes, and Admin operations.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{access_token}}",
				"type": "string"
			}
		]
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8080/api/v1",
			"type": "string"
		},
		{
			"key": "access_token",
			"value": "",
			"type": "string"
		},
		{
			"key": "session_id",
			"value": "1",
			"type": "string"
		},
		{
			"key": "note_id",
			"value": "1",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "1. Kuppi Sessions",
			"description": "Kuppi session management endpoints.\n\nBase Path: `/api/v1/kuppi/sessions`",
			"item": [
				{
					"name": "Public/Read Endpoints",
					"description": "Endpoints accessible by all authenticated users",
					"item": [
						{
							"name": "1.1 Get All Sessions",
							"request": {
								"method": "GET",
								"header": [],
								"url": {
									"raw": "{{base_url}}/kuppi/sessions?page=0&size=10&sortBy=scheduledStartTime&sortDirection=ASC",
									"host": ["{{base_url}}"],
									"path": ["kuppi", "sessions"],
									"query": [
										{"key": "page", "value": "0", "description": "Page number (0-indexed)"},
										{"key": "size", "value": "10", "description": "Items per page"},
										{"key": "sortBy", "value": "scheduledStartTime", "description": "Sort field"},
										{"key": "sortDirection", "value": "ASC", "description": "Sort direction"}
									]
								},
								"description": "View all approved Kuppi sessions.\n\n**Permission:** `KUPPI:READ`\n\n**Roles:** All authenticated users"
							}
						},
						{
							"name": "1.2 Get Session by ID",
							"request": {
								"method": "GET",
								"header": [],
								"url": {
									"raw": "{{base_url}}/kuppi/sessions/{{session_id}}",
									"host": ["{{base_url}}"],
									"path": ["kuppi", "sessions", "{{session_id}}"]
								},
								"description": "View a specific Kuppi session.\n\n**Permission:** `KUPPI:READ`\n\n**Roles:** All authenticated users"
							}
						},
						{
							"name": "1.3 Search Sessions",
							"request": {
								"method": "GET",
								"header": [],
								"url": {
									"raw": "{{base_url}}/kuppi/sessions/search?keyword=programming&page=0&size=10",
									"host": ["{{base_url}}"],
									"path": ["kuppi", "sessions", "search"],
									"query": [
										{"key": "keyword", "value": "programming", "description": "Search keyword"},
										{"key": "page", "value": "0"},
										{"key": "size", "value": "10"}
									]
								},
								"description": "Search sessions by keyword.\n\n**Permission:** `KUPPI:READ`\n\n**Roles:** All authenticated users"
							}
						},
						{
							"name": "1.4 Search by Subject",
							"request": {
								"method": "GET",
								"header": [],
								"url": {
									"raw": "{{base_url}}/kuppi/sessions/search/subject?subject=Data Structures&page=0&size=10",
									"host": ["{{base_url}}"],
									"path": ["kuppi", "sessions", "search", "subject"],
									"query": [
										{"key": "subject", "value": "Data Structures", "description": "Subject name"},
										{"key": "page", "value": "0"},
										{"key": "size", "value": "10"}
									]
								},
								"description": "Search sessions by subject.\n\n**Permission:** `KUPPI:READ`\n\n**Roles:** All authenticated users"
							}
						},
						{
							"name": "1.5 Search by Host",
							"request": {
								"method": "GET",
								"header": [],
								"url": {
									"raw": "{{base_url}}/kuppi/sessions/search/host?hostName=John&page=0&size=10",
									"host": ["{{base_url}}"],
									"path": ["kuppi", "sessions", "search", "host"],
									"query": [
										{"key": "hostName", "value": "John", "description": "Host name"},
										{"key": "page", "value": "0"},
										{"key": "size", "value": "10"}
									]
								},
								"description": "Search sessions by host/lecturer name.\n\n**Permission:** `KUPPI:READ`\n\n**Roles:** All authenticated users"
							}
						},
						{
							"name": "1.6 Search by Date Range",
							"request": {
								"method": "GET",
								"header": [],
								"url": {
									"raw": "{{base_url}}/kuppi/sessions/search/date?startDate=2026-02-01T00:00:00&endDate=2026-02-28T23:59:59&page=0&size=10",
									"host": ["{{base_url}}"],
									"path": ["kuppi", "sessions", "search", "date"],
									"query": [
										{"key": "startDate", "value": "2026-02-01T00:00:00", "description": "Start date (ISO format)"},
										{"key": "endDate", "value": "2026-02-28T23:59:59", "description": "End date (ISO format)"},
										{"key": "page", "value": "0"},
										{"key": "size", "value": "10"}
									]
								},
								"description": "Search sessions by date range.\n\n**Permission:** `KUPPI:READ`\n\n**Roles:** All authenticated users"
							}
						},
						{
							"name": "1.7 Get Upcoming Sessions",
							"request": {
								"method": "GET",
								"header": [],
								"url": {
									"raw": "{{base_url}}/kuppi/sessions/upcoming?page=0&size=10",
									"host": ["{{base_url}}"],
									"path": ["kuppi", "sessions", "upcoming"],
									"query": [
										{"key": "page", "value": "0"},
										{"key": "size", "value": "10"}
									]
								},
								"description": "Get all upcoming Kuppi sessions.\n\n**Permission:** `KUPPI:READ`\n\n**Roles:** All authenticated users"
							}
						},
						{
							"name": "1.13 Get My Sessions",
							"request": {
								"method": "GET",
								"header": [],
								"url": {
									"raw": "{{base_url}}/kuppi/sessions/my?page=0&size=10",
									"host": ["{{base_url}}"],
									"path": ["kuppi", "sessions", "my"],
									"query": [
										{"key": "page", "value": "0"},
										{"key": "size", "value": "10"}
									]
								},
								"description": "Get own created sessions.\n\n**Permission:** `KUPPI:READ`\n\n**Roles:** All authenticated users"
							}
						}
					]
				},
				{
					"name": "Kuppi Student Endpoints",
					"description": "Endpoints for Kuppi Students to manage their sessions",
					"item": [
						{
							"name": "1.8 Create Session",
							"request": {
								"method": "POST",
								"header": [
									{"key": "Content-Type", "value": "application/json"}
								],
								"body": {
									"mode": "raw",
									"raw": "{\n    \"title\": \"Data Structures - Binary Trees\",\n    \"description\": \"Learn about binary trees, traversals, and operations\",\n    \"subject\": \"Data Structures\",\n    \"scheduledStartTime\": \"2026-02-25T14:00:00\",\n    \"scheduledEndTime\": \"2026-02-25T16:00:00\",\n    \"maxParticipants\": 30,\n    \"location\": \"Online - Zoom\",\n    \"meetingLink\": \"https://zoom.us/j/123456789\"\n}"
								},
								"url": {
									"raw": "{{base_url}}/kuppi/sessions",
									"host": ["{{base_url}}"],
									"path": ["kuppi", "sessions"]
								},
								"description": "Create a new Kuppi session.\n\n**Permission:** `KUPPI:CREATE`\n\n**Roles:** Kuppi Student, Admin, Super Admin"
							}
						},
						{
							"name": "1.9 Update Session",
							"request": {
								"method": "PUT",
								"header": [
									{"key": "Content-Type", "value": "application/json"}
								],
								"body": {
									"mode": "raw",
									"raw": "{\n    \"title\": \"Updated Session Title\",\n    \"description\": \"Updated description\",\n    \"maxParticipants\": 40\n}"
								},
								"url": {
									"raw": "{{base_url}}/kuppi/sessions/{{session_id}}",
									"host": ["{{base_url}}"],
									"path": ["kuppi", "sessions", "{{session_id}}"]
								},
								"description": "Update own Kuppi session.\n\n**Permission:** `KUPPI:UPDATE`\n\n**Roles:** Kuppi Student (own session), Admin, Super Admin"
							}
						},
						{
							"name": "1.10 Cancel Session",
							"request": {
								"method": "POST",
								"header": [],
								"url": {
									"raw": "{{base_url}}/kuppi/sessions/{{session_id}}/cancel?reason=Schedule conflict",
									"host": ["{{base_url}}"],
									"path": ["kuppi", "sessions", "{{session_id}}", "cancel"],
									"query": [
										{"key": "reason", "value": "Schedule conflict", "description": "Cancellation reason (optional)"}
									]
								},
								"description": "Cancel own Kuppi session.\n\n**Permission:** `KUPPI:CANCEL`\n\n**Roles:** Kuppi Student (own session), Admin, Super Admin"
							}
						},
						{
							"name": "1.11 Reschedule Session",
							"request": {
								"method": "POST",
								"header": [],
								"url": {
									"raw": "{{base_url}}/kuppi/sessions/{{session_id}}/reschedule?newStartTime=2026-02-26T14:00:00&newEndTime=2026-02-26T16:00:00",
									"host": ["{{base_url}}"],
									"path": ["kuppi", "sessions", "{{session_id}}", "reschedule"],
									"query": [
										{"key": "newStartTime", "value": "2026-02-26T14:00:00", "description": "New start time"},
										{"key": "newEndTime", "value": "2026-02-26T16:00:00", "description": "New end time"}
									]
								},
								"description": "Reschedule own Kuppi session.\n\n**Permission:** `KUPPI:RESCHEDULE`\n\n**Roles:** Kuppi Student (own session), Admin, Super Admin"
							}
						},
						{
							"name": "1.12 Delete Session",
							"request": {
								"method": "DELETE",
								"header": [],
								"url": {
									"raw": "{{base_url}}/kuppi/sessions/{{session_id}}",
									"host": ["{{base_url}}"],
									"path": ["kuppi", "sessions", "{{session_id}}"]
								},
								"description": "Delete own Kuppi session (soft delete).\n\n**Permission:** `KUPPI:DELETE`\n\n**Roles:** Kuppi Student (own session), Admin, Super Admin"
							}
						},
						{
							"name": "1.14 Get My Analytics",
							"request": {
								"method": "GET",
								"header": [],
								"url": {
									"raw": "{{base_url}}/kuppi/sessions/my/analytics",
									"host": ["{{base_url}}"],
									"path": ["kuppi", "sessions", "my", "analytics"]
								},
								"description": "Get analytics for own sessions and notes.\n\n**Permission:** `KUPPI:VIEW_ANALYTICS`\n\n**Roles:** Kuppi Student, Admin, Super Admin"
							}
						}
					]
				}
			]
		},
		{
			"name": "2. Kuppi Notes",
			"description": "Kuppi notes management endpoints.\n\nBase Path: `/api/v1/kuppi/notes`",
			"item": [
				{
					"name": "Read/Download Endpoints",
					"description": "Endpoints accessible by all authenticated users",
					"item": [
						{
							"name": "2.1 Get All Notes",
							"request": {
								"method": "GET",
								"header": [],
								"url": {
									"raw": "{{base_url}}/kuppi/notes?page=0&size=10",
									"host": ["{{base_url}}"],
									"path": ["kuppi", "notes"],
									"query": [
										{"key": "page", "value": "0"},
										{"key": "size", "value": "10"}
									]
								},
								"description": "View all approved notes.\n\n**Permission:** `KUPPI_NOTE:READ`\n\n**Roles:** All authenticated users"
							}
						},
						{
							"name": "2.2 Get Notes for Session",
							"request": {
								"method": "GET",
								"header": [],
								"url": {
									"raw": "{{base_url}}/kuppi/notes/session/{{session_id}}",
									"host": ["{{base_url}}"],
									"path": ["kuppi", "notes", "session", "{{session_id}}"]
								},
								"description": "View notes for a specific session.\n\n**Permission:** `KUPPI_NOTE:READ`\n\n**Roles:** All authenticated users"
							}
						},
						{
							"name": "2.3 Get Note by ID",
							"request": {
								"method": "GET",
								"header": [],
								"url": {
									"raw": "{{base_url}}/kuppi/notes/{{note_id}}",
									"host": ["{{base_url}}"],
									"path": ["kuppi", "notes", "{{note_id}}"]
								},
								"description": "View a specific note.\n\n**Permission:** `KUPPI_NOTE:READ`\n\n**Roles:** All authenticated users"
							}
						},
						{
							"name": "2.4 Download Note (Record)",
							"request": {
								"method": "GET",
								"header": [],
								"url": {
									"raw": "{{base_url}}/kuppi/notes/{{note_id}}/download",
									"host": ["{{base_url}}"],
									"path": ["kuppi", "notes", "{{note_id}}", "download"]
								},
								"description": "Record a note download.\n\n**Permission:** `KUPPI_NOTE:DOWNLOAD`\n\n**Roles:** All authenticated users"
							}
						},
						{
							"name": "2.5 Download Note File",
							"request": {
								"method": "GET",
								"header": [],
								"url": {
									"raw": "{{base_url}}/kuppi/notes/{{note_id}}/download/file",
									"host": ["{{base_url}}"],
									"path": ["kuppi", "notes", "{{note_id}}", "download", "file"]
								},
								"description": "Download the actual note file from S3.\n\n**Permission:** `KUPPI_NOTE:DOWNLOAD`\n\n**Roles:** All authenticated users"
							}
						},
						{
							"name": "2.6 Search Notes",
							"request": {
								"method": "GET",
								"header": [],
								"url": {
									"raw": "{{base_url}}/kuppi/notes/search?keyword=algorithms&page=0&size=10",
									"host": ["{{base_url}}"],
									"path": ["kuppi", "notes", "search"],
									"query": [
										{"key": "keyword", "value": "algorithms"},
										{"key": "page", "value": "0"},
										{"key": "size", "value": "10"}
									]
								},
								"description": "Search notes by keyword.\n\n**Permission:** `KUPPI_NOTE:SEARCH`\n\n**Roles:** All authenticated users"
							}
						},
						{
							"name": "2.10 Get My Notes",
							"request": {
								"method": "GET",
								"header": [],
								"url": {
									"raw": "{{base_url}}/kuppi/notes/my?page=0&size=10",
									"host": ["{{base_url}}"],
									"path": ["kuppi", "notes", "my"],
									"query": [
										{"key": "page", "value": "0"},
										{"key": "size", "value": "10"}
									]
								},
								"description": "Get own uploaded notes.\n\n**Permission:** `KUPPI_NOTE:READ`\n\n**Roles:** All authenticated users"
							}
						}
					]
				},
				{
					"name": "Kuppi Student Endpoints",
					"description": "Endpoints for Kuppi Students to manage their notes",
					"item": [
						{
							"name": "2.7 Upload Note with File",
							"request": {
								"method": "POST",
								"header": [],
								"body": {
									"mode": "formdata",
									"formdata": [
										{"key": "title", "value": "Data Structures Notes", "type": "text", "description": "Note title"},
										{"key": "description", "value": "Complete notes on binary trees", "type": "text", "description": "Note description"},
										{"key": "sessionId", "value": "1", "type": "text", "description": "Associated session ID (optional)"},
										{"key": "allowDownload", "value": "true", "type": "text", "description": "Allow download"},
										{"key": "file", "type": "file", "src": [], "description": "Note file (PDF, DOC, etc.)"}
									]
								},
								"url": {
									"raw": "{{base_url}}/kuppi/notes/upload",
									"host": ["{{base_url}}"],
									"path": ["kuppi", "notes", "upload"]
								},
								"description": "Upload a new note with file to S3.\n\n**Permission:** `KUPPI_NOTE:CREATE`\n\n**Roles:** Kuppi Student, Admin, Super Admin"
							}
						},
						{
							"name": "2.8 Update Note with File",
							"request": {
								"method": "PUT",
								"header": [],
								"body": {
									"mode": "formdata",
									"formdata": [
										{"key": "title", "value": "Updated Note Title", "type": "text"},
										{"key": "description", "value": "Updated description", "type": "text"},
										{"key": "allowDownload", "value": "true", "type": "text"},
										{"key": "file", "type": "file", "src": [], "description": "New file (optional)"}
									]
								},
								"url": {
									"raw": "{{base_url}}/kuppi/notes/{{note_id}}/upload",
									"host": ["{{base_url}}"],
									"path": ["kuppi", "notes", "{{note_id}}", "upload"]
								},
								"description": "Update own note with optional new file.\n\n**Permission:** `KUPPI_NOTE:UPDATE`\n\n**Roles:** Kuppi Student (own note), Admin, Super Admin"
							}
						},
						{
							"name": "2.9 Delete Note",
							"request": {
								"method": "DELETE",
								"header": [],
								"url": {
									"raw": "{{base_url}}/kuppi/notes/{{note_id}}",
									"host": ["{{base_url}}"],
									"path": ["kuppi", "notes", "{{note_id}}"]
								},
								"description": "Delete own note (soft delete).\n\n**Permission:** `KUPPI_NOTE:DELETE`\n\n**Roles:** Kuppi Student (own note), Admin, Super Admin"
							}
						}
					]
				}
			]
		},
		{
			"name": "3. Kuppi Admin",
			"description": "Admin endpoints for Kuppi management.\n\nBase Path: `/api/v1/admin/kuppi`",
			"item": [
				{
					"name": "Session Management",
					"description": "Admin endpoints for session management",
					"item": [
						{
							"name": "3.1 Admin Update Session",
							"request": {
								"method": "PUT",
								"header": [
									{"key": "Content-Type", "value": "application/json"}
								],
								"body": {
									"mode": "raw",
									"raw": "{\n    \"title\": \"Admin Updated Title\",\n    \"description\": \"Admin updated description\"\n}"
								},
								"url": {
									"raw": "{{base_url}}/admin/kuppi/sessions/{{session_id}}",
									"host": ["{{base_url}}"],
									"path": ["admin", "kuppi", "sessions", "{{session_id}}"]
								},
								"description": "Edit any Kuppi session (admin override).\n\n**Permission:** `KUPPI:ADMIN_UPDATE`\n\n**Roles:** Admin, Super Admin"
							}
						},
						{
							"name": "3.2 Admin Delete Session (Soft)",
							"request": {
								"method": "DELETE",
								"header": [],
								"url": {
									"raw": "{{base_url}}/admin/kuppi/sessions/{{session_id}}",
									"host": ["{{base_url}}"],
									"path": ["admin", "kuppi", "sessions", "{{session_id}}"]
								},
								"description": "Soft delete any Kuppi session.\n\n**Permission:** `KUPPI:ADMIN_DELETE`\n\n**Roles:** Admin, Super Admin"
							}
						},
						{
							"name": "3.3 Permanently Delete Session ⚠️",
							"request": {
								"method": "DELETE",
								"header": [],
								"url": {
									"raw": "{{base_url}}/admin/kuppi/sessions/{{session_id}}/permanent",
									"host": ["{{base_url}}"],
									"path": ["admin", "kuppi", "sessions", "{{session_id}}", "permanent"]
								},
								"description": "⚠️ DANGER: Permanently delete a Kuppi session from the database.\n\n**Permission:** `KUPPI:PERMANENT_DELETE`\n\n**Roles:** Super Admin only"
							}
						}
					]
				},
				{
					"name": "Note Management",
					"description": "Admin endpoints for note management",
					"item": [
						{
							"name": "3.4 Admin Update Note",
							"request": {
								"method": "PUT",
								"header": [
									{"key": "Content-Type", "value": "application/json"}
								],
								"body": {
									"mode": "raw",
									"raw": "{\n    \"title\": \"Admin Updated Note Title\",\n    \"description\": \"Admin updated description\",\n    \"allowDownload\": false\n}"
								},
								"url": {
									"raw": "{{base_url}}/admin/kuppi/notes/{{note_id}}",
									"host": ["{{base_url}}"],
									"path": ["admin", "kuppi", "notes", "{{note_id}}"]
								},
								"description": "Edit any note (admin override).\n\n**Permission:** `KUPPI_NOTE:ADMIN_UPDATE`\n\n**Roles:** Admin, Super Admin"
							}
						},
						{
							"name": "3.5 Admin Delete Note (Soft)",
							"request": {
								"method": "DELETE",
								"header": [],
								"url": {
									"raw": "{{base_url}}/admin/kuppi/notes/{{note_id}}",
									"host": ["{{base_url}}"],
									"path": ["admin", "kuppi", "notes", "{{note_id}}"]
								},
								"description": "Soft delete any note.\n\n**Permission:** `KUPPI_NOTE:ADMIN_DELETE`\n\n**Roles:** Admin, Super Admin"
							}
						},
						{
							"name": "3.6 Permanently Delete Note ⚠️",
							"request": {
								"method": "DELETE",
								"header": [],
								"url": {
									"raw": "{{base_url}}/admin/kuppi/notes/{{note_id}}/permanent",
									"host": ["{{base_url}}"],
